modules = ["web", "nodejs-22"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "dist"
run = ["node_modules/.bin/wrangler", "dev", "--config", "dist/server/wrangler.json", "--port", "5000", "--ip", "0.0.0.0"]

[userenv]

[userenv.shared]
SUPABASE_URL = "https://mvpjxcypvnoydgipzolu.supabase.co"
VITE_SUPABASE_URL = "https://mvpjxcypvnoydgipzolu.supabase.co"
VITE_SUPABASE_PROJECT_ID = "mvpjxcypvnoydgipzolu"
